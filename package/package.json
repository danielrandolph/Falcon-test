{
  "type": "module",
  "name": "@falcon/ui-kit",
  "version": "1.15.1",
  "description": "UI Kit for the AgVend platform",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./dist/legacy": {
      "types": "./dist/legacy/index.d.ts",
      "default": "./dist/legacy/index.js"
    },
    "./dist/index.css": "./dist/index.css",
    "./CHANGELOG.md?raw": "./CHANGELOG.md",
    "./less/style.less": "./less/style.less",
    "./less/variables.less": "./less/variables.less",
    "./package.json": "./package.json"
  },
  "sideEffects": [
    "dist/**/*.css",
    "less/**/*.less"
  ],
  "files": [
    "dist",
    "less",
    "src"
  ],
  "dependencies": {
    "classnames": "^2.5.1",
    "react-aria": "^3.47.0",
    "react-aria-components": "^1.16.0",
    "tailwind-merge": "^3.5.0",
    "tailwind-variants": "^3.2.2"
  },
  "peerDependencies": {
    "lucide-react": "^1.7.0",
    "react": "^18.2.0"
  },
  "devDependencies": {
    "@rsbuild/plugin-less": "^1.5.0",
    "@rsbuild/plugin-react": "^1.4.0",
    "@rslib/core": "^0.13.2",
    "@tailwindcss/postcss": "^4.2.2",
    "tailwindcss": "^4.2.2",
    "tailwindcss-animate": "^1.0.7",
    "tailwindcss-react-aria-components": "^2.0.1"
  },
  "scripts": {}
}
